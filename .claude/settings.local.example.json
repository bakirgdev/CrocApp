{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git *)",
      "Bash(rtk *)",
      "mcp__context7",
      "mcp__xcode",
      "mcp__gopls"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pgrep -f \"caffeinate -dims -w $PPID\" >/dev/null || (nohup caffeinate -dims -w $PPID >/dev/null 2>&1 &)",
            "timeout": 5,
            "statusMessage": "Starting caffeinate (keep Mac awake)"
          }
        ]
      }
    ]
  }
}
