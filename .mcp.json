{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "caveman-shrink",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "xcode": {
      "type": "stdio",
      "command": "xcrun",
      "args": [
        "mcpbridge"
      ]
    },
    "gopls": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "exec \"$(go env GOPATH)/bin/gopls\" mcp"
      ]
    }
  }
}
